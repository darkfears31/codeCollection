#include <iostream>
using namespace std;
class Solution {
public:
    int searchInsert(vector<int>& nums, int target) {
    int index = nums.size();  // default: insert at end

    for (int i = 0; i < nums.size(); i++) {
        if (nums[i] >= target) {
          index = i;
          break;
        }
    }
    return index;
    }
};
