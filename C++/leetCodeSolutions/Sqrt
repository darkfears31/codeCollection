#include <iostream>
using namespace std;
class Solution {
public:
    int mySqrt(int x) {
        if(x<2) return x;
        long long start{1}, end{x/2}, mid{0};
        while(start<=end){
            mid = start + (end-start)/2;
            if(mid * mid <= x) start = mid+1;
            else {end = mid -1;}
        }
        return end;
    }
};
