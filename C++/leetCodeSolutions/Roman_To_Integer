#include <iostream>
using namespace std;
class Solution {
public:
    int val(char c){
            if (c == 'I') return 1;
            if (c == 'V') return 5;
            if (c == 'X') return 10;
            if (c == 'L') return 50;
            if (c == 'C') return 100;
            if (c == 'D') return 500;
            return 1000;
    }
    int romanToInt(string s) {
        int sum=0;
        for(int i=0;i<s.size();i++){
            int curVal = val(s[i]);
            int nextVal = (i+1<s.size() ? val(s[i+1]) : 0);

            if(curVal<nextVal) sum-=curVal;
            else{
                sum+=curVal;
            }
        }
        return sum;
    }
};