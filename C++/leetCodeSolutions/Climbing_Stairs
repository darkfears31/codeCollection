#include <iostream>
using namespace std;
class Solution {
public:
    int climbStairs(int n) {
       int s1 = 1, s2 = 1;
       if(n==0 || n==1) return 1;
       else{
            for(int i = 2;i<=n;i++){
                int temp = s1+s2;
                s1=s2;
                s2=temp;
            }
        }
       return s2;
    }
};
