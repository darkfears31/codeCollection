#include <iostream>
using namespace std;
class Solution {
public:
    vector<int> getRow(int rowIndex) {
    vector<vector<int>> v;
    for(int i=0;i<=rowIndex; i++){
        v.push_back(vector<int>(i+1,1)); //Add vectors filled with 1's 
    }
    for(int i=2;i<=rowIndex;i++){
        for(int j=1;j<v[i].size()-1;j++){
            v[i][j]=v[i-1][j-1]+v[i-1][j]; //Access previous vectors integers.
        }
    }
    return v[rowIndex];//Return Required Row
    }
};
